# Copy this file to ".env" and fill in real values. NEVER commit .env.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Carbon Emission API (choose one provider)
# Provider options: "climatiq" or "carbon_interface"
CARBON_PROVIDER=climatiq
CLIMATIQ_API_KEY=
CARBON_INTERFACE_API_KEY=

# LLM recommendation layer (OPTIONAL — system works without it)
# If left blank, the app uses the deterministic rule-based engine only.
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Model
MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.35
# Inference device: "cpu" (safe default for serving) or "0" to use GPU 0.
INFERENCE_DEVICE=cpu

# Database
DATABASE_URL=sqlite:///waste_app.db
