# Copy this file to ".env" and fill in real values. NEVER commit .env.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Carbon Emission API (choose one provider)
# Provider options: "climatiq" or "carbon_interface"
CARBON_PROVIDER=climatiq
CLIMATIQ_API_KEY=
CARBON_INTERFACE_API_KEY=

# LLM text layer for the Decision Making Module (OPTIONAL — v3.6).
# Rewrites the recommendation verdict/pros/cons in child-friendly language,
# localized to the request country. Blank key = the deterministic local
# knowledge grid (the app fully works without it; LLM failures auto-fallback).
# Any OpenAI-compatible chat-completions endpoint works — free-tier options:
#   Groq        LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
#               LLM_MODEL=llama-3.3-70b-versatile        (key: console.groq.com)
#   OpenRouter  LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
#               LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Gemini      LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
#               LLM_MODEL=gemini-flash-latest   (2.0/2.5-flash have NO free
#               quota for new keys — the "latest" alias is the one that works)
#   Ollama      LLM_API_URL=http://localhost:11434/v1/chat/completions
#               LLM_MODEL=llama3.2   LLM_API_KEY=ollama  (100% local)
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions

# YouTube Data API v3 (OPTIONAL — Action Protocol tutorial videos).
# The LLM writes a localized search query; this key lets the backend resolve
# it to ONE live tutorial embed (maxResults=1). Blank key = the verified
# universal fallback video, zero network. Free quota 10,000 units/day
# (each search costs 100; results are cached per query).
# Get a key: console.cloud.google.com → enable "YouTube Data API v3".
YOUTUBE_API_KEY=

# Dual-Tower Hybrid model pipeline (100% local).
# Stage 1 locator: SPECIALIZED waste OBJECT DETECTION (YOLOv8-N fine-tuned on
# a blended universal waste corpus; only fires on waste-like objects; box
# areas drive the carbon scaling). Auto-downloads on first load if missing.
# A/B alternatives: models/yolov8m-seg-trash.pt (segmenter) or yolo26x-seg.pt.
MODEL_PATH=models/yolov8n-waste-det.pt
# Stage 2 material classifier (supervised ViT fine-tuned on TrashNet-enhanced,
# ~343 MB into the HF cache on first load).
VIT_MODEL_NAME=edwinpalegre/ee8225-group4-vit-trashnet-enhanced
# Stage 1 threshold is recall-first (LOW) — Stage 2 provides per-item certainty.
CONFIDENCE_THRESHOLD=0.15
# Inference device for BOTH stages: "cpu" (safe default) or "0" to use GPU 0.
INFERENCE_DEVICE=0

# Database
DATABASE_URL=sqlite:///waste_app.db
