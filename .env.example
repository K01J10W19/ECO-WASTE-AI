# Copy this file to ".env" and fill in real values. NEVER commit .env.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Carbon Emission API (choose one provider)
# Provider options: "climatiq" or "carbon_interface"
CARBON_PROVIDER=climatiq
CLIMATIQ_API_KEY=
CARBON_INTERFACE_API_KEY=

# LLM recommendation layer (OPTIONAL — system works without it)
# If left blank, the app uses the deterministic rule-based engine only.
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Dual-Tower Hybrid model pipeline (100% local).
# Stage 1 locator: SPECIALIZED waste OBJECT DETECTION (YOLOv8-N fine-tuned on
# a blended universal waste corpus; only fires on waste-like objects; box
# areas drive the carbon scaling). Auto-downloads on first load if missing.
# A/B alternatives: models/yolov8m-seg-trash.pt (segmenter) or yolo26x-seg.pt.
MODEL_PATH=models/yolov8n-waste-det.pt
# Stage 2 material classifier (supervised ViT fine-tuned on TrashNet-enhanced,
# ~343 MB into the HF cache on first load).
VIT_MODEL_NAME=edwinpalegre/ee8225-group4-vit-trashnet-enhanced
# Stage 1 threshold is recall-first (LOW) — Stage 2 provides per-item certainty.
CONFIDENCE_THRESHOLD=0.15
# Inference device for BOTH stages: "cpu" (safe default) or "0" to use GPU 0.
INFERENCE_DEVICE=0

# Database
DATABASE_URL=sqlite:///waste_app.db
